# Fastify Server Configuration
PORT=5000
HOST=localhost
# Set this to your frontend domain in production to restrict CORS
# e.g. FRONTEND_URL=https://app.legalai.in
FRONTEND_URL=

# Supabase Configuration
# The URL of your Supabase project (e.g., https://your-project-id.supabase.co)
SUPABASE_URL=your_supabase_project_url
# The Service Role Key (secret) for backend admin operations (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# The Publishable Key (public) if you need client-level access control
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Storage bucket used for raw document uploads (Phase 2 ingestion)
SUPABASE_STORAGE_BUCKET=legal-docs

# PostgreSQL Connection String (Direct Connection on Port 5432)
# Used by pg and LangGraph Checkpointer (e.g., postgresql://postgres.your-project-id:your-password@aws-0-us-west-1.pooler.supabase.com:5432/postgres)
DATABASE_URL=postgresql://username:password@host:5432/database

# LangChain & OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Cohere
COHERE_API_KEY=your_cohere_api_key

# Razorpay Billing (Phase 8)
# Get these from https://dashboard.razorpay.com/app/keys
# Use rzp_test_ keys for development, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# Get from Razorpay Dashboard → Webhooks → your webhook → Secret
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# Resend (email alerts at 80% usage)
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
