{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node --conditions=production dist/server.js",
    "dev": "tsx watch server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#config/*.js": {
      "production": "./dist/src/config/*.js",
      "default": "./src/config/*.js"
    },
    "#plugins/*.js": {
      "production": "./dist/src/plugins/*.js",
      "default": "./src/plugins/*.js"
    },
    "#middlewares/*.js": {
      "production": "./dist/src/middlewares/*.js",
      "default": "./src/middlewares/*.js"
    },
    "#domains/*.js": {
      "production": "./dist/src/domains/*.js",
      "default": "./src/domains/*.js"
    },
    "#utils/*.js": {
      "production": "./dist/src/utils/*.js",
      "default": "./src/utils/*.js"
    }
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/sse": "^0.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.2",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.3",
    "@langchain/openai": "^1.5.2",
    "@langchain/textsplitters": "^1.0.1",
    "@supabase/supabase-js": "^2.108.2",
    "cohere-ai": "^8.0.0",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "gpt-tokenizer": "^3.4.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
